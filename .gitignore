############################################################
# .NET / Visual Studio
# Updated: 2026
# Based on:
# https://github.com/github/gitignore
############################################################

############################################################
# User-specific files
############################################################
*.suo
*.user
*.userosscache
*.userprefs
*.sln.docstates
*.DotSettings.user

############################################################
# IDEs
############################################################

# Visual Studio
.vs/
*.VC.db
*.VC.VC.opendb
ipch/

# JetBrains Rider
.idea/
*.sln.iml

############################################################
# Build output
############################################################
[Bb]in/
[Oo]bj/
[Ll]og/
[Dd]ebug*/
[Rr]elease*/
artifacts/
bld/
x64/
x86/

############################################################
# Test & Coverage
############################################################
[Tt]est[Rr]esult*/
*.coverage
*.coveragexml
*.VisualState.xml
BenchmarkDotNet.Artifacts/

############################################################
# Generated / Temporary files
############################################################
*.cache
*.tmp
*.log
*.bak
~$*
*~

############################################################
# Symbols
############################################################
*.pdb

############################################################
# SQL Server
############################################################
*.mdf
*.ldf
*.ndf

############################################################
# ASP.NET Launch Settings
############################################################
**/Properties/launchSettings.json

############################################################
# NuGet
############################################################
*.nupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

############################################################
# Publish
############################################################
publish/
PublishScripts/
*.publishproj
*.publishsettings
*.pubxml
*.azurePubxml

############################################################
# Docker
############################################################

# Local Docker Compose configuration
docker.compose.yml
docker-compose.override.yml
**/docker-compose.override.yml

# Environment variables
.env
.env.*

# Keep examples under version control
!.env.example
!docker.compose.example.yml

############################################################
# Node.js
############################################################
node_modules/

############################################################
# Python
############################################################
__pycache__/
*.pyc

############################################################
# YAML user configuration
############################################################
*.yml
!docker.compose.example.yml
